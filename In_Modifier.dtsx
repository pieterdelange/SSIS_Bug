          <ProjectItem
            Name="TestTheBreakpoint.cs"
            Encoding="UTF8"><![CDATA[using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace ST_908ee73319df408fbdef73d68d08414f
{
    internal class TestTheBreakpoint
    {
        string TheMessageBeforeTheBreakpoint;
        string TheMessageAfterTheBreakpoint;
        public TestTheBreakpoint(in string TheMessageBeforeTheBreakpoint, in string TheMessageAfterTheBreakpoint) {
            this.TheMessageBeforeTheBreakpoint = TheMessageBeforeTheBreakpoint;
            this.TheMessageAfterTheBreakpoint = TheMessageAfterTheBreakpoint;
        }

        public string ReturnTheMessageBeforeTheBreakpoint()
        {
            return TheMessageBeforeTheBreakpoint;
        }

        public string ReturnTheMessageAfterTheBreakpoint()
        {
            return TheMessageAfterTheBreakpoint;
        }
    }
}]]></ProjectItem>
