            string ThisIsForTheBreakpoint = "Test";
            MessageBox.Show("I think I meade a logic error here. But I can't debug it");
            BreakpointMessages = new TestTheBreakpoint("The breakpoint should hit after this messagebox.", "Did the breakpoint hit?");

            MessageBox.Show("Did the breakpoint hit?");



            Dts.TaskResult = (int)ScriptResults.Success;
		}

