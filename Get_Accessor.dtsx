          <ProjectItem
            Name="TestTheBreakpoint.cs"
            Encoding="UTF8"><![CDATA[using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace ST_908ee73319df408fbdef73d68d08414f
{
    internal class TestTheBreakpoint
    {
        public string TheMessageBeforeTheBreakpoint { set => TheMessageBeforeTheBreakpoint = value; get { return TheMessageBeforeTheBreakpoint != null ? TheMessageBeforeTheBreakpoint : "NA"; } }
        public string TheMessageAfterTheBreakpoint { set=> TheMessageAfterTheBreakpoint = value; get { return TheMessageAfterTheBreakpoint != null ? TheMessageAfterTheBreakpoint : "NA"; } }
        public TestTheBreakpoint(string TheMessageBeforeTheBreakpoint,string TheMessageAfterTheBreakpoint) {
            this.TheMessageBeforeTheBreakpoint = TheMessageBeforeTheBreakpoint;
            this.TheMessageBeforeTheBreakpoint = TheMessageAfterTheBreakpoint;
        }
         
        public string ReturnTheMessageBeforeTheBreakpoint()
        {
            return TheMessageBeforeTheBreakpoint;
        }

        public string ReturnTheMessageAfterTheBreakpoint()
        {
            return TheMessageAfterTheBreakpoint;
        }
    }
}]]></ProjectItem>
